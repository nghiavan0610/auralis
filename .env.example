# Auralis Developer Environment Variables
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# -----------------------------------------------------------------------------
# APP-LEVEL KEYS (Developer Keys)
# These are YOUR keys as the developer, embedded in the app for all users
# -----------------------------------------------------------------------------

# RevenueCat Public SDK Key
# Get this from https://app.revenuecat.com/
# See REVENUECAT_SETUP.md for detailed instructions
VITE_REVENUECAT_PUBLIC_KEY=appl_your_revenuecat_public_key_here

# Backend OpenAI API Key (for Pro tier summary generation)
# This is used server-side in the Rust backend
# Set this when running the app or in your production environment
AURALIS_OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# USER-PROVIDED KEYS (Not for .env)
# Users enter their own keys in the Settings UI:
# - Soniox API key (for cloud translation mode)
# - Google Cloud TTS API key (for Google TTS)
# - ElevenLabs API key (for ElevenLabs TTS)
# - Anthropic API key (for alternative summary provider)
# -----------------------------------------------------------------------------
# These are entered per-user in the app Settings, not in environment variables
# Each user has their own account and enters their own key
# -----------------------------------------------------------------------------
